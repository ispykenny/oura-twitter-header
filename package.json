    "sharp": "^0.33.3",
    "twitter-api-v2": "^1.16.3"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.3.2",
    "@nestjs/schematics": "^10.1.1",
    "@types/node": "^20.12.7",
